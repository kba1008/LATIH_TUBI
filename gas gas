/**
 * PENTING: PENYELESAIAN RALAT PERMISSION URLFETCHAPP
 * 
 * Jika anda mendapat ralat: "You do not have permission to call UrlFetchApp.fetch..."
 * Ralat ini berpunca dari skrip tidak diberikan kebenaran luaran (external_request) oleh Google.
 * 
 * LANGKAH PENYELESAIAN MUDAH:
 * 1. Di editor Google Apps Script, pilih fungsi `forceAuthorization` di menu 'Run'.
 * 2. Klik butang "Run" (Jalankan).
 * 3. Tetingkap "Authorization Required" akan muncul secara automatik. Klik "Review Permissions".
 * 4. Sila pilih akaun Google anda.
 * 5. Jika amaran "Google hasn't verified this app" muncul, klik "Advanced" dan klik "Go to ... (unsafe)".
 * 6. Klik "Allow". 
 * 7. Setelah berjaya, anda boleh mula jalankan fungsi `testGroqAPIKey`.
 */

function forceAuthorization() {
  // Fungsi ini direka khas dan diubahsuai TANPA block 'try-catch'.
  // Ini adalah kaedah paling berkesan untuk memaksa IDE Apps Script menangkap ralat 
  // pelaksanaan dan mencetuskan paparan tetingkap kelulusan OAuth dengan tepat.
  var dummyUrl = "https://www.google.com";
  var response = UrlFetchApp.fetch(dummyUrl);
  SpreadsheetApp.getActiveSpreadsheet();
  Logger.log("Kebenaran telah berjaya disahkan. Sila jalankan testGroqAPIKey sekarang. Kod respons: " + response.getResponseCode());
}

function doPost(e) {
  try {
    var data = JSON.parse(e.postData.contents);
    var action = data.action;
    var ss = SpreadsheetApp.getActiveSpreadsheet();

    // Penyelarasan Nama Sheet secara dinamik (Gantikan 'Leaderboard' dengan 'PELAJAR')
    var pSheet = ss.getSheetByName("PELAJAR") || ss.getSheetByName("Leaderboard");
    if (pSheet && pSheet.getName() === "Leaderboard") {
       pSheet.setName("PELAJAR"); // Migrasi automatik ke nama baru
    }
    if (!pSheet) {
      pSheet = ss.insertSheet("PELAJAR");
      pSheet.appendRow(["Nama", "Markah", "Tarikh Terakhir", "Sejarah Topik"]);
    }
    // Pastikan tajuk kolum ke-4 (Sejarah Topik) wujud
    if (pSheet.getRange(1, 4).getValue() === "") {
      pSheet.getRange(1, 4).setValue("Sejarah Topik");
    }

    if (action === "init") {
      // 1. Baca API Key
      var keySheet = ss.getSheetByName("API_KEY");
      if (!keySheet) return createJsonResponse({ error: "Tab 'API_KEY' tiada." });
      var apiKey = keySheet.getRange("A1").getValue();
      
      // 2. Baca Topik dari tab SOALAN secara dinamik kolum A ke bawah
      var qSheet = ss.getSheetByName("SOALAN") || ss.getSheetByName("soalan");
      if (!qSheet) return createJsonResponse({ error: "Tab 'SOALAN' tiada dalam Google Sheet." });
      
      var lastRow = qSheet.getLastRow();
      var questions = [];
      if (lastRow > 0) {
        var qData = qSheet.getRange(1, 1, lastRow, 1).getValues();
        questions = qData.map(function(r) { return r[0] ? r[0].toString().trim() : ""; }).filter(function(q) { return q !== ""; });
      }
      
      // 3. Semak Markah & Rekod Sejarah Pelajar
      var userPoints = 0;
      var answeredTopics = [];
      if (data.name) {
         var pData = pSheet.getDataRange().getValues();
         for(var i=1; i<pData.length; i++) {
            if(pData[i][0] === data.name) {
               userPoints = pData[i][1] || 0;
               try {
                 var strTopics = pData[i][3];
                 if(strTopics) answeredTopics = JSON.parse(strTopics);
               } catch(err) {
                 answeredTopics = [];
               }
               break;
            }
         }
      }

      return createJsonResponse({
        success: true,
        apiKey: apiKey,
        questions: questions,
        userPoints: userPoints,
        answeredTopics: answeredTopics
      });
    }
    
    if (action === "save_score") {
      var pData = pSheet.getDataRange().getValues();
      var found = false;
      var topicJSON = JSON.stringify(data.answeredTopics || []);
      for (var i = 1; i < pData.length; i++) {
        if (pData[i][0] === data.name) {
          pSheet.getRange(i + 1, 2).setValue(data.points);
          pSheet.getRange(i + 1, 3).setValue(new Date());
          pSheet.getRange(i + 1, 4).setValue(topicJSON);
          found = true;
          break;
        }
      }
      if (!found) {
        pSheet.appendRow([data.name, data.points, new Date(), topicJSON]);
      }
      return createJsonResponse({ success: true });
    }
    
    if (action === "get_leaderboard") {
      var scores = [];
      var pData = pSheet.getDataRange().getValues();
      for (var i = 1; i < pData.length; i++) {
        if (pData[i][0]) {
          scores.push({ name: pData[i][0], points: pData[i][1] || 0 });
        }
      }
      // Susun markah dari tertinggi ke terendah
      scores.sort(function(a, b) { return b.points - a.points; });
      scores = scores.slice(0, 10); // Ambil Top 10 sahaja
      
      return createJsonResponse({ success: true, leaderboard: scores });
    }

    if (action === "get_all_students") {
      if (data.adminPwd !== "101010") return createJsonResponse({ error: "Katalaluan Admin Tidak Sah." });
      var students = [];
      var pData = pSheet.getDataRange().getValues();
      for (var i = 1; i < pData.length; i++) {
        if (pData[i][0]) {
          students.push({ name: pData[i][0], points: pData[i][1] || 0 });
        }
      }
      return createJsonResponse({ success: true, students: students });
    }

    if (action === "admin_action") {
      if (data.adminPwd !== "101010") return createJsonResponse({ error: "Akses ditolak" });
      
      if (data.task === "reset_all") {
        var lastRow = pSheet.getLastRow();
        if (lastRow > 1) {
          pSheet.getRange(2, 2, lastRow - 1, 1).setValue(0); // Kosongkan Markah
          pSheet.getRange(2, 4, lastRow - 1, 1).setValue("[]"); // Reset Sejarah Topik
        }
        return createJsonResponse({ success: true });
      }
      
      if (data.task === "reset_student" || data.task === "delete_student") {
        var pData = pSheet.getDataRange().getValues();
        for (var i = 1; i < pData.length; i++) {
          if (pData[i][0] === data.targetName) {
            if (data.task === "reset_student") {
              pSheet.getRange(i + 1, 2).setValue(0);
              pSheet.getRange(i + 1, 4).setValue("[]");
            } else if (data.task === "delete_student") {
              pSheet.deleteRow(i + 1);
            }
            break;
          }
        }
        return createJsonResponse({ success: true });
      }
    }
    
    return createJsonResponse({ error: "Aksi tidak dikenali." });

  } catch (err) {
    return createJsonResponse({ error: err.message });
  }
}

function doGet(e) {
  return ContentService.createTextOutput("Sistem Backend AI berfungsi. Sila semak Editor GAS anda untuk langkah penyelesaian UrlFetchApp.").setMimeType(ContentService.MimeType.TEXT);
}

function createJsonResponse(obj) {
  return ContentService.createTextOutput(JSON.stringify(obj)).setMimeType(ContentService.MimeType.JSON);
}

/**
 * FUNGSI UJIAN KHAS: Uji API Key Groq dan Selesaikan Isu "Permission UrlFetchApp"
 */
function testGroqAPIKey() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var keySheet = ss.getSheetByName("API_KEY");
  
  if (!keySheet) {
    Logger.log("RALAT: Tab 'API_KEY' tiada. Sila cipta tab bernama 'API_KEY' dan masukkan API Key anda pada sel A1.");
    return;
  }
  
  var apiKey = keySheet.getRange("A1").getValue();
  if (!apiKey || apiKey.toString().trim() === "") {
    Logger.log("RALAT: API Key tiada di sel A1 dalam tab 'API_KEY'.");
    return;
  }
  
  var url = "https://api.groq.com/openai/v1/chat/completions";
  var payload = {
    "model": "llama-3.3-70b-versatile",
    "messages": [{"role": "user", "content": "Hai AI, adakah anda berfungsi? Jawab dengan ringkas dalam Bahasa Melayu."}],
    "max_tokens": 250,
    "temperature": 0.5
  };
  
  var options = {
    "method": "post",
    "headers": {
      "Authorization": "Bearer " + apiKey.toString().trim(),
      "Content-Type": "application/json"
    },
    "payload": JSON.stringify(payload),
    "muteHttpExceptions": true
  };
  
  try {
    var response = UrlFetchApp.fetch(url, options);
    var responseCode = response.getResponseCode();
    var responseText = response.getContentText();
    
    if (responseCode === 200) {
      var data = JSON.parse(responseText);
      var aiMessage = data.choices[0].message.content;
      Logger.log("\n--- UJIAN BERJAYA ---\nStatus: 200 OK\nAPI Key anda SAH.\nMaklum balas AI: " + aiMessage + "\n\nSistem anda kini sedia digunakan sepenuhnya.\n-----------------------");
    } else {
      Logger.log("\n--- UJIAN GAGAL ---\nKod Ralat: " + responseCode + "\nMesej Ralat dari Groq: " + responseText + "\nSila semak semula model, API Key atau kuota anda.\n-----------------------");
    }
  } catch (e) {
    Logger.log("RALAT PELAKSANAAN SCRIPT: " + e.message + "\nSila pastikan anda mengizinkan skrip ini mengakses maklumat dari luar (Allow Permissions) dengan menjalankan fungsi forceAuthorization().");
  }
}
